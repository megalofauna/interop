{
	"name": "interop",
	"version": "0.1.0",
	"description": "Angular library for interoperable components and data patterns",
	"keywords": [
		"angular",
		"interop",
		"library",
		"components",
		"typescript"
	],
	"author": "Christopher Salmon",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/christophersalmon/interop.git"
	},
	"main": "dist/index.js",
	"module": "dist/index.esm.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "ng build",
		"build:watch": "ng build --watch",
		"build:icons": "tsx tools/gen-phosphor-icons.ts Working-Iconset-Files/svgs/phosphor/regular src/lib/iconsets/phosphor Ph",
		"test": "ng test",
		"publish:npm": "npm publish dist/",
		"serve": "ng serve demo",
		"start": "ng serve demo",
		"demo": "ng serve demo --open",
		"docs:api": "typedoc --plugin typedoc-plugin-markdown --out docs/api src/public-api.ts --tsconfig tsconfig.lib.json --excludePrivate --excludeProtected --hideBreadcrumbs",
		"docs:dev": "mkdocs serve",
		"docs:build": "mkdocs build",
		"docs:serve": "mkdocs serve -a localhost:3001",
		"docs": "npm run docs:api && mkdocs build"
	},
	"peerDependencies": {
		"@angular/common": "^17.0.0",
		"@angular/core": "^17.0.0",
		"@angular/forms": "^17.0.0",
		"rxjs": "^7.8.0",
		"typescript": "^5.2.0"
	},
	"devDependencies": {
		"@angular-devkit/build-angular": "^21.0.3",
		"@angular-eslint/builder": "^21.1.0",
		"@angular-eslint/eslint-plugin": "^21.1.0",
		"@angular-eslint/eslint-plugin-template": "^21.1.0",
		"@angular-eslint/schematics": "^21.1.0",
		"@angular-eslint/template-parser": "^21.1.0",
		"@angular/build": "^21.0.3",
		"@angular/cli": "^21.0.3",
		"@angular/common": "^21.0.3",
		"@angular/compiler": "^21.0.3",
		"@angular/compiler-cli": "^21.0.3",
		"@angular/core": "^21.0.3",
		"@angular/forms": "^21.0.3",
		"@angular/platform-browser": "^21.0.3",
		"@angular/platform-browser-dynamic": "^21.0.3",
		"@angular/router": "^21.0.3",
		"@types/jasmine": "^5.1.0",
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "^8.49.0",
		"@typescript-eslint/parser": "^8.49.0",
		"eslint": "^9.39.2",
		"fast-xml-parser": "^5.3.3",
		"jasmine-core": "^5.1.0",
		"karma": "^6.4.0",
		"karma-chrome-launcher": "^3.2.0",
		"karma-coverage": "^2.2.0",
		"karma-jasmine": "^5.1.0",
		"karma-jasmine-html-reporter": "^2.1.0",
		"ng-packagr": "^21.0.0",
		"rxjs": "^7.8.0",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.15",
		"typedoc-plugin-markdown": "^4.9.0",
		"typescript": "^5.2.0",
		"zone.js": "^0.15.0"
	}
}
