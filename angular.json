{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"interop": {
			"projectType": "library",
			"root": "projects/interop",
			"sourceRoot": "projects/interop/src",
			"prefix": "itx",
			"architect": {
				"build": {
					"builder": "@angular-devkit/build-angular:ng-packagr",
					"options": {
						"project": "projects/interop/ng-package.json"
					},
					"configurations": {
						"production": {
							"tsConfig": "projects/interop/tsconfig.lib.prod.json"
						},
						"development": {
							"tsConfig": "projects/interop/tsconfig.lib.json"
						}
					},
					"defaultConfiguration": "production"
				},
				"test": {
					"builder": "@angular-devkit/build-angular:karma",
					"options": {
						"tsConfig": "projects/interop/tsconfig.spec.json",
						"polyfills": ["zone.js", "zone.js/testing"]
					}
				}
			}
		},
		"demo": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss",
					"skipTests": true
				},
				"@schematics/angular:class": {
					"skipTests": true
				},
				"@schematics/angular:directive": {
					"skipTests": true
				},
				"@schematics/angular:guard": {
					"skipTests": true
				},
				"@schematics/angular:interceptor": {
					"skipTests": true
				},
				"@schematics/angular:pipe": {
					"skipTests": true
				},
				"@schematics/angular:resolver": {
					"skipTests": true
				},
				"@schematics/angular:service": {
					"skipTests": true
				}
			},
			"root": "projects/demo",
			"sourceRoot": "projects/demo/src",
			"prefix": "dtx",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"browser": "projects/demo/src/main.ts",
						"tsConfig": "projects/demo/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/demo/public"
							}
						],
						"styles": ["projects/demo/src/styles.scss"],
						"stylePreprocessorOptions": {
							"includePaths": ["projects/interop/src", "projects/demo/src"]
						}
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "1MB",
									"maximumError": "1.5MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "8kB",
									"maximumError": "16kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "demo:build:production"
						},
						"development": {
							"buildTarget": "demo:build:development"
						}
					},
					"defaultConfiguration": "development"
				}
			}
		},
		"protocol": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss",
					"skipTests": true
				},
				"@schematics/angular:class": {
					"skipTests": true
				},
				"@schematics/angular:directive": {
					"skipTests": true
				},
				"@schematics/angular:service": {
					"skipTests": true
				}
			},
			"root": "projects/protocol",
			"sourceRoot": "projects/protocol/src",
			"prefix": "ptx",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"browser": "projects/protocol/src/main.ts",
						"index": "projects/protocol/src/index.html",
						"tsConfig": "projects/protocol/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*.md",
								"input": "projects/protocol/src/content",
								"output": "content"
							},
							{
								"glob": "**/*.woff2",
								"input": "projects/protocol/src/fonts",
								"output": "fonts"
							}
						],
						"styles": ["projects/protocol/src/styles.scss"],
						"stylePreprocessorOptions": {
							"includePaths": ["projects/interop/src", "projects/protocol/src"]
						}
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "1MB",
									"maximumError": "1.5MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "8kB",
									"maximumError": "16kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "protocol:build:production"
						},
						"development": {
							"buildTarget": "protocol:build:development"
						}
					},
					"defaultConfiguration": "development"
				}
			}
		}
	},
	"cli": {
		"packageManager": "npm"
	}
}
