/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/app",
    "types": [],
    "baseUrl": "../../",
    "paths": {
      "interop": ["src/public-api"],
      "interop/*": ["src/*"],
      "@interop/composites": ["projects/composites/src/public-api.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../src/lib/**/*.ts",
    "../../src/types/**/*.ts",
    "../../projects/composites/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "../../src/**/*.spec.ts",
    "../../src/examples/**/*"
  ]
}
